<Window x:Class="MilitaryGeo.Desktop.MainWorkSpace"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:local="clr-namespace:MilitaryGeo.Desktop"
        xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
        xmlns:skin="clr-namespace:Syncfusion.SfSkinManager;assembly=Syncfusion.SfSkinManager.WPF"
        skin:SfSkinManager.Theme="{skin:SkinManagerExtension ThemeName=MaterialLight}"
        mc:Ignorable="d"
        Title="Military Geo - Hệ thống quản lý dữ liệu địa lý quân sự" 
        Height="800" 
        Width="1400"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#F5F5F5">

    <Window.Resources>
        <!-- Sidebar Button Style -->
        <Style x:Key="SidebarButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,0,0,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="MainBorder"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="8"
                                Margin="10,2">
                            <ContentPresenter VerticalAlignment="Center"
                                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="MainBorder" Property="Background" Value="White"/>
                                <Setter Property="Foreground" Value="#4a7c2c"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainBorder" Property="Background" Value="#5a8c3c"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="MainBorder" Property="Background" Value="#F0F0F0"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Icon Button Style -->
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#4a7c2c"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="20">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E8F5E9"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Navigation Bar -->
        <Border Grid.Row="0" 
                Background="White"
                BorderBrush="#E0E0E0"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo Section -->
                <StackPanel Grid.Column="0" 
                           Orientation="Horizontal" 
                           VerticalAlignment="Center"
                           Margin="20,0">
                    <Ellipse Width="35" Height="35" Fill="#4a7c2c" Margin="0,0,10,0">
                        <Ellipse.OpacityMask>
                            <VisualBrush>
                                <VisualBrush.Visual>
                                    <Grid>
                                        <Path Fill="White" 
                                              Data="M12,2 L17,7 L17,12 L12,17 L7,12 L7,7 Z"
                                              Stretch="Uniform"
                                              Margin="5"/>
                                        <Ellipse Width="8" Height="8" Fill="#FFD700"/>
                                    </Grid>
                                </VisualBrush.Visual>
                            </VisualBrush>
                        </Ellipse.OpacityMask>
                    </Ellipse>
                    <TextBlock Text="MILITARY GEO" 
                              FontSize="18" 
                              FontWeight="Bold" 
                              Foreground="#4a7c2c"
                              VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Search Bar -->
                <Border Grid.Column="1" 
                       Background="#F5F5F5"
                       CornerRadius="20"
                       Margin="20,0"
                       VerticalAlignment="Center"
                       Height="40"
                       MaxWidth="600">
                    <Grid>
                        <TextBox x:Name="txtSearch"
                                Text="Tìm kiếm..."
                                FontSize="13"
                                Foreground="#999999"
                                Background="Transparent"
                                BorderThickness="0"
                                VerticalAlignment="Center"
                                Padding="20,0,40,0"
                                GotFocus="txtSearch_GotFocus"
                                LostFocus="txtSearch_LostFocus"/>
                        <TextBlock Text="🔍" 
                                  FontSize="16"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Center"
                                  Margin="0,0,15,0"
                                  IsHitTestVisible="False"/>
                    </Grid>
                </Border>

                <!-- User Profile Section -->
                <StackPanel Grid.Column="2" 
                           Orientation="Horizontal" 
                           Margin="0,0,20,0"
                           VerticalAlignment="Center">
                    
                    <!-- Notification Button -->
                    <Button Style="{StaticResource IconButtonStyle}"
                           Margin="5,0"
                           ToolTip="Thông báo">
                        <TextBlock Text="🔔" FontSize="18"/>
                    </Button>

                    <!-- Settings Button -->
                    <Button Style="{StaticResource IconButtonStyle}"
                           Margin="5,0"
                           ToolTip="Cài đặt">
                        <TextBlock Text="⚙" FontSize="18"/>
                    </Button>

                    <!-- User Profile -->
                    <Border Background="#E8F5E9"
                           CornerRadius="20"
                           Padding="10,5,15,5"
                           Margin="10,0,0,0"
                           Cursor="Hand">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="35" Height="35" 
                                    Fill="#4a7c2c"
                                    Margin="0,0,10,0">
                                <Ellipse.OpacityMask>
                                    <VisualBrush>
                                        <VisualBrush.Visual>
                                            <TextBlock Text="👤" 
                                                      FontSize="20"
                                                      Foreground="White"/>
                                        </VisualBrush.Visual>
                                    </VisualBrush>
                                </Ellipse.OpacityMask>
                            </Ellipse>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="txtUserName"
                                          Text="Administrator" 
                                          FontSize="13" 
                                          FontWeight="SemiBold"
                                          Foreground="#333333"/>
                                <TextBlock Text="Quản trị viên" 
                                          FontSize="11" 
                                          Foreground="#666666"/>
                            </StackPanel>
                            <TextBlock Text="▼" 
                                      FontSize="10" 
                                      Foreground="#666666"
                                      VerticalAlignment="Center"
                                      Margin="10,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Logout Button -->
                    <Button Style="{StaticResource IconButtonStyle}"
                           Margin="10,0,0,0"
                           ToolTip="Đăng xuất"
                           Click="btnLogout_Click">
                        <TextBlock Text="🚪" FontSize="18"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar Menu -->
            <Border Grid.Column="0" 
                   Background="#4a7c2c"
                   BorderBrush="#E0E0E0"
                   BorderThickness="0,0,1,0">
                <StackPanel Margin="5,10">
                    <!-- Menu Header -->
                    <TextBlock Text="MENU CHÍNH" 
                              FontSize="11" 
                              FontWeight="SemiBold"
                              Foreground="#C8E6C9"
                              Margin="15,15,15,10"/>

                    <!-- Dashboard -->
                    <RadioButton Style="{StaticResource SidebarButtonStyle}"
                                GroupName="Menu"
                                IsChecked="True">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📊" FontSize="18" Margin="0,0,12,0"/>
                            <TextBlock Text="Dashboard" 
                                      VerticalAlignment="Center"
                                      FontWeight="Medium"/>
                        </StackPanel>
                    </RadioButton>

                    <!-- Map Management -->
                    <RadioButton Style="{StaticResource SidebarButtonStyle}"
                                GroupName="Menu">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🗺️" FontSize="18" Margin="0,0,12,0"/>
                            <TextBlock Text="Quản lý bản đồ" 
                                      VerticalAlignment="Center"
                                      FontWeight="Medium"/>
                        </StackPanel>
                    </RadioButton>

                    <!-- Data Management -->
                    <RadioButton Style="{StaticResource SidebarButtonStyle}"
                                GroupName="Menu">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📁" FontSize="18" Margin="0,0,12,0"/>
                            <TextBlock Text="Quản lý dữ liệu" 
                                      VerticalAlignment="Center"
                                      FontWeight="Medium"/>
                        </StackPanel>
                    </RadioButton>

                    <!-- Coordinates -->
                    <RadioButton Style="{StaticResource SidebarButtonStyle}"
                                GroupName="Menu">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📍" FontSize="18" Margin="0,0,12,0"/>
                            <TextBlock Text="Tọa độ địa lý" 
                                      VerticalAlignment="Center"
                                      FontWeight="Medium"/>
                        </StackPanel>
                    </RadioButton>

                    <!-- Reports -->
                    <RadioButton Style="{StaticResource SidebarButtonStyle}"
                                GroupName="Menu">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📈" FontSize="18" Margin="0,0,12,0"/>
                            <TextBlock Text="Báo cáo" 
                                      VerticalAlignment="Center"
                                      FontWeight="Medium"/>
                        </StackPanel>
                    </RadioButton>

                    <!-- Users Management -->
                    <RadioButton Style="{StaticResource SidebarButtonStyle}"
                                GroupName="Menu">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👥" FontSize="18" Margin="0,0,12,0"/>
                            <TextBlock Text="Quản lý người dùng" 
                                      VerticalAlignment="Center"
                                      FontWeight="Medium"/>
                        </StackPanel>
                    </RadioButton>

                    <!-- Separator -->
                    <Border Height="1" 
                           Background="#6b9e4d" 
                           Opacity="0.3"
                           Margin="15,15"/>

                    <!-- Settings -->
                    <RadioButton Style="{StaticResource SidebarButtonStyle}"
                                GroupName="Menu">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙️" FontSize="18" Margin="0,0,12,0"/>
                            <TextBlock Text="Cài đặt hệ thống" 
                                      VerticalAlignment="Center"
                                      FontWeight="Medium"/>
                        </StackPanel>
                    </RadioButton>

                    <!-- Help -->
                    <RadioButton Style="{StaticResource SidebarButtonStyle}"
                                GroupName="Menu">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="❓" FontSize="18" Margin="0,0,12,0"/>
                            <TextBlock Text="Hướng dẫn" 
                                      VerticalAlignment="Center"
                                      FontWeight="Medium"/>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>
            </Border>

            <!-- Content Area -->
            <Grid Grid.Column="1" Margin="20">
                <!-- Dashboard Content -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- Welcome Section -->
                        <Border Background="White"
                               CornerRadius="8"
                               Padding="30"
                               Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="Chào mừng trở lại!" 
                                          FontSize="28" 
                                          FontWeight="Bold"
                                          Foreground="#333333"
                                          Margin="0,0,0,10"/>
                                <TextBlock Text="Hệ thống quản lý dữ liệu địa lý quân sự" 
                                          FontSize="14" 
                                          Foreground="#666666"/>
                            </StackPanel>
                        </Border>

                        <!-- Statistics Cards -->
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Card 1: Total Maps -->
                            <Border Grid.Column="0" 
                                   Background="White"
                                   CornerRadius="8"
                                   Padding="20"
                                   Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="🗺️" FontSize="32" Margin="0,0,0,10"/>
                                    <TextBlock Text="Tổng bản đồ" 
                                              FontSize="13" 
                                              Foreground="#666666"
                                              Margin="0,0,0,5"/>
                                    <TextBlock Text="1,234" 
                                              FontSize="28" 
                                              FontWeight="Bold"
                                              Foreground="#4a7c2c"/>
                                </StackPanel>
                            </Border>

                            <!-- Card 2: Data Files -->
                            <Border Grid.Column="1" 
                                   Background="White"
                                   CornerRadius="8"
                                   Padding="20"
                                   Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="📁" FontSize="32" Margin="0,0,0,10"/>
                                    <TextBlock Text="Tệp dữ liệu" 
                                              FontSize="13" 
                                              Foreground="#666666"
                                              Margin="0,0,0,5"/>
                                    <TextBlock Text="5,678" 
                                              FontSize="28" 
                                              FontWeight="Bold"
                                              Foreground="#2196F3"/>
                                </StackPanel>
                            </Border>

                            <!-- Card 3: Coordinates -->
                            <Border Grid.Column="2" 
                                   Background="White"
                                   CornerRadius="8"
                                   Padding="20"
                                   Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="📍" FontSize="32" Margin="0,0,0,10"/>
                                    <TextBlock Text="Tọa độ" 
                                              FontSize="13" 
                                              Foreground="#666666"
                                              Margin="0,0,0,5"/>
                                    <TextBlock Text="12,345" 
                                              FontSize="28" 
                                              FontWeight="Bold"
                                              Foreground="#FF9800"/>
                                </StackPanel>
                            </Border>

                            <!-- Card 4: Users -->
                            <Border Grid.Column="3" 
                                   Background="White"
                                   CornerRadius="8"
                                   Padding="20">
                                <StackPanel>
                                    <TextBlock Text="👥" FontSize="32" Margin="0,0,0,10"/>
                                    <TextBlock Text="Người dùng" 
                                              FontSize="13" 
                                              Foreground="#666666"
                                              Margin="0,0,0,5"/>
                                    <TextBlock Text="89" 
                                              FontSize="28" 
                                              FontWeight="Bold"
                                              Foreground="#9C27B0"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Recent Activity -->
                        <Border Background="White"
                               CornerRadius="8"
                               Padding="20">
                            <StackPanel>
                                <TextBlock Text="Hoạt động gần đây" 
                                          FontSize="18" 
                                          FontWeight="Bold"
                                          Foreground="#333333"
                                          Margin="0,0,0,20"/>

                                <syncfusion:SfDataGrid x:Name="gridRecentActivity"
                                                      AutoGenerateColumns="False"
                                                      ColumnSizer="Star"
                                                      GridLinesVisibility="Horizontal"
                                                      HeaderRowHeight="40"
                                                      RowHeight="45">
                                    <syncfusion:SfDataGrid.Columns>
                                        <syncfusion:GridTextColumn HeaderText="Thời gian" 
                                                                  MappingName="Time" 
                                                                  Width="150"/>
                                        <syncfusion:GridTextColumn HeaderText="Hoạt động" 
                                                                  MappingName="Activity"/>
                                        <syncfusion:GridTextColumn HeaderText="Người thực hiện" 
                                                                  MappingName="User" 
                                                                  Width="200"/>
                                        <syncfusion:GridTextColumn HeaderText="Trạng thái" 
                                                                  MappingName="Status" 
                                                                  Width="150"/>
                                    </syncfusion:SfDataGrid.Columns>
                                </syncfusion:SfDataGrid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>

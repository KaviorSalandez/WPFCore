<UserControl x:Class="MilitaryGeo.Desktop.UserControls.NguoiDung"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MilitaryGeo.Desktop.UserControls"
             xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200"
             Background="#F5F5F5">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <Border Grid.Row="0" 
                Background="White"
                CornerRadius="8"
                Padding="25"
                Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Quản lý người dùng" 
                              FontSize="24" 
                              FontWeight="Bold"
                              Foreground="#333333"
                              Margin="0,0,0,5"/>
                    <TextBlock Text="Danh sách người dùng trong hệ thống" 
                              FontSize="13" 
                              Foreground="#666666"/>
                </StackPanel>

                <StackPanel Grid.Column="1" 
                           Orientation="Horizontal"
                           VerticalAlignment="Center">
                    <Button Content="➕ Thêm người dùng"
                            Background="#4a7c2c"
                            Foreground="White"
                            Padding="15,10"
                            FontSize="13"
                            FontWeight="SemiBold"
                            BorderThickness="0"
                            Cursor="Hand"
                            Margin="10,0,0,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                   CornerRadius="6"
                                                   Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" 
                                                                VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#3d6624"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Data Grid Section -->
        <Border Grid.Row="1" 
                Background="White"
                CornerRadius="8"
                Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Search and Filter -->
                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                           Background="#F5F5F5"
                           CornerRadius="6"
                           Height="40"
                           MaxWidth="400"
                           HorizontalAlignment="Left">
                        <Grid>
                            <TextBox x:Name="txtSearchUser"
                                    Text="Tìm kiếm người dùng..."
                                    FontSize="13"
                                    Foreground="#999999"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    VerticalAlignment="Center"
                                    Padding="15,0,40,0"/>
                            <TextBlock Text="🔍" 
                                      FontSize="14"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Center"
                                      Margin="0,0,12,0"
                                      IsHitTestVisible="False"/>
                        </Grid>
                    </Border>

                    <Button Grid.Column="1"
                            Content="🔄 Làm mới"
                            Background="Transparent"
                            Foreground="#4a7c2c"
                            BorderBrush="#4a7c2c"
                            BorderThickness="1"
                            Padding="12,8"
                            FontSize="13"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                   BorderBrush="{TemplateBinding BorderBrush}"
                                                   BorderThickness="{TemplateBinding BorderThickness}"
                                                   CornerRadius="6"
                                                   Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" 
                                                                VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#E8F5E9"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>

                <!-- User Data Grid -->
                <syncfusion:SfDataGrid x:Name="gridUsers"
                                      Grid.Row="1"
                                      AutoGenerateColumns="False"
                                      ColumnSizer="Star"
                                      GridLinesVisibility="Horizontal"
                                      HeaderRowHeight="45"
                                      RowHeight="50"
                                      SelectionMode="Single"
                                      AllowEditing="False"
                                      AllowSorting="True"
                                      AllowFiltering="True">
                    <syncfusion:SfDataGrid.Columns>
                        <syncfusion:GridTextColumn HeaderText="ID" 
                                                  MappingName="Id" 
                                                  Width="80"
                                                  TextAlignment="Center"/>
                        <syncfusion:GridTextColumn HeaderText="Tên đăng nhập" 
                                                  MappingName="Username" 
                                                  Width="150"/>
                        <syncfusion:GridTextColumn HeaderText="Họ và tên" 
                                                  MappingName="FullName" 
                                                  Width="200"/>
                        <syncfusion:GridTextColumn HeaderText="Email" 
                                                  MappingName="Email" 
                                                  Width="220"/>
                        <syncfusion:GridTextColumn HeaderText="Số điện thoại" 
                                                  MappingName="Phone" 
                                                  Width="130"/>
                        <syncfusion:GridTextColumn HeaderText="Vai trò" 
                                                  MappingName="Role" 
                                                  Width="120"/>
                        <syncfusion:GridTextColumn HeaderText="Trạng thái" 
                                                  MappingName="Status" 
                                                  Width="110"/>
                        <syncfusion:GridTemplateColumn HeaderText="Thao tác" 
                                                      Width="150"
                                                      TextAlignment="Center">
                            <syncfusion:GridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" 
                                              HorizontalAlignment="Center">
                                        <Button Content="✏️" 
                                               ToolTip="Chỉnh sửa"
                                               Width="30" 
                                               Height="30"
                                               Margin="2"
                                               Background="Transparent"
                                               BorderThickness="0"
                                               Cursor="Hand"/>
                                        <Button Content="🗑️" 
                                               ToolTip="Xóa"
                                               Width="30" 
                                               Height="30"
                                               Margin="2"
                                               Background="Transparent"
                                               BorderThickness="0"
                                               Cursor="Hand"/>
                                    </StackPanel>
                                </DataTemplate>
                            </syncfusion:GridTemplateColumn.CellTemplate>
                        </syncfusion:GridTemplateColumn>
                    </syncfusion:SfDataGrid.Columns>
                </syncfusion:SfDataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>

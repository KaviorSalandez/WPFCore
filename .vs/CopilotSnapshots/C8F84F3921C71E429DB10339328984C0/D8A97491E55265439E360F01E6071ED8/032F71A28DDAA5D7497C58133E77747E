<Window x:Class="MilitaryGeo.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MilitaryGeo.Desktop"
        xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
        xmlns:skin="clr-namespace:Syncfusion.SfSkinManager;assembly=Syncfusion.SfSkinManager.WPF"
        skin:SfSkinManager.Theme="{skin:SkinManagerExtension ThemeName=MaterialLight}"
        mc:Ignorable="d"
        Title="Military Geo - Đăng nhập" 
        Height="600" 
        Width="1100"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">
    
    <Window.Resources>
        <!-- Military Green Gradient Background -->
        <LinearGradientBrush x:Key="LoginGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#2d5016" Offset="0.0"/>
            <GradientStop Color="#4a7c2c" Offset="0.5"/>
            <GradientStop Color="#6b8e23" Offset="1.0"/>
        </LinearGradientBrush>

        <!-- Button Style -->
        <Style x:Key="LoginButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#4a7c2c"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8"
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3d6624"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Toggle Password Button Style -->
        <Style x:Key="TogglePasswordButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="35"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <TextBlock x:Name="Icon" 
                                      Text="👁" 
                                      FontSize="18" 
                                      HorizontalAlignment="Center" 
                                      VerticalAlignment="Center"
                                      Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Icon" Property="Foreground" Value="#4a7c2c"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F5F5F5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource LoginGradient}" 
            CornerRadius="20">
        <Grid>
            <!-- Close Button -->
            <Button x:Name="btnClose"
                    Content="✕"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,10,10,0"
                    Width="40"
                    Height="40"
                    Background="Transparent"
                    Foreground="White"
                    FontSize="20"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="btnClose_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            CornerRadius="20">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#88FFFFFF"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Side - Illustration -->
                <Grid Grid.Column="0" Margin="50">
                    <StackPanel VerticalAlignment="Center">
                        <Viewbox Width="300" Height="300" Margin="0,0,0,30">
                            <Canvas Width="500" Height="500">
                                <!-- Military Map Icon -->
                                <Path Fill="White" Opacity="0.9"
                                      Data="M250,50 L450,150 L450,350 L250,450 L50,350 L50,150 Z M250,100 L100,175 L100,325 L250,400 L400,325 L400,175 Z"/>
                                <Ellipse Canvas.Left="225" Canvas.Top="225" Width="50" Height="50" Fill="#FFD700"/>
                                <Path Stroke="White" StrokeThickness="8" 
                                      Data="M250,100 L250,250 M150,250 L350,250"/>
                            </Canvas>
                        </Viewbox>
                        
                        <TextBlock Text="MILITARY GEO" 
                                   FontSize="36" 
                                   FontWeight="Bold" 
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,10"/>
                        
                        <TextBlock Text="Hệ thống quản lý dữ liệu địa lý quân sự" 
                                   FontSize="16" 
                                   Foreground="WhiteSmoke"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- Right Side - Login Form -->
                <Border Grid.Column="1" 
                        Background="White" 
                        CornerRadius="20,0,0,20"
                        Margin="0,50,50,50"
                        Effect="{DynamicResource z-depth3}">
                    <StackPanel VerticalAlignment="Center" 
                                Margin="70,60">
                        
                        <!-- Login Title -->
                        <TextBlock Text="Đăng nhập" 
                                   FontSize="32" 
                                   FontWeight="Bold" 
                                   Foreground="#333333"
                                   Margin="0,0,0,10"
                                   TextWrapping="Wrap"/>
                        
                        <TextBlock Text="Vui lòng nhập thông tin tài khoản" 
                                   FontSize="14" 
                                   Foreground="#999999"
                                   Margin="0,0,0,40"
                                   TextWrapping="Wrap"/>

                        <!-- Username Input -->
                        <syncfusion:SfTextInputLayout 
                            Hint="Tên đăng nhập"
                            HelperText="Nhập tên đăng nhập của bạn"
                            Margin="0,0,0,25"
                            ContainerType="Outlined"
                            OutlineCornerRadius="8">
                            <TextBox x:Name="txtUsername" 
                                     FontSize="14"
                                     Padding="12,14"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     KeyDown="OnKeyDown"/>
                        </syncfusion:SfTextInputLayout>

                        <!-- Password Input with Toggle -->
                        <Grid Margin="0,0,0,30">
                            <syncfusion:SfTextInputLayout 
                                x:Name="passwordLayout"
                                Hint="Mật khẩu"
                                HelperText="Nhập mật khẩu của bạn"
                                ContainerType="Outlined"
                                OutlineCornerRadius="8">
                                <PasswordBox x:Name="txtPassword" 
                                            FontSize="14"
                                            Padding="12,14,50,14"
                                            BorderThickness="0"
                                            Background="Transparent"
                                            KeyDown="OnKeyDown"/>
                            </syncfusion:SfTextInputLayout>
                            
                            <!-- Hidden TextBox for showing password -->
                            <TextBox x:Name="txtPasswordVisible"
                                     FontSize="14"
                                     Padding="12,14,50,14"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Visibility="Collapsed"
                                     Margin="1,32,1,22"
                                     KeyDown="OnKeyDown"/>
                            
                            <!-- Toggle Password Visibility Button -->
                            <ToggleButton x:Name="btnTogglePassword"
                                         Style="{StaticResource TogglePasswordButtonStyle}"
                                         HorizontalAlignment="Right"
                                         VerticalAlignment="Top"
                                         Margin="0,38,8,0"
                                         Checked="btnTogglePassword_Checked"
                                         Unchecked="btnTogglePassword_Unchecked"/>
                        </Grid>

                        <!-- Forgot Password Link -->
                        <TextBlock HorizontalAlignment="Right"
                                  Margin="0,0,0,35">
                            <Hyperlink x:Name="lnkForgotPassword"
                                      Foreground="#4a7c2c"
                                      TextDecorations="None"
                                      FontSize="13"
                                      FontWeight="Medium"
                                      Click="lnkForgotPassword_Click">
                                Quên mật khẩu?
                            </Hyperlink>
                        </TextBlock>

                        <!-- Login Button -->
                        <Button x:Name="btnLogin"
                                Content="ĐĂNG NHẬP"
                                Style="{StaticResource LoginButtonStyle}"
                                Click="btnLogin_Click"/>

                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>

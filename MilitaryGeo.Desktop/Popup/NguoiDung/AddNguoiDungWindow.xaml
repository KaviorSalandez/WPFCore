<Window x:Class="MilitaryGeo.Desktop.Popup.NguoiDung.AddNguoiDungWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MilitaryGeo.Desktop.Popup.NguoiDung"
        xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
        xmlns:skin="clr-namespace:Syncfusion.SfSkinManager;assembly=Syncfusion.SfSkinManager.WPF"
        skin:SfSkinManager.Theme="{skin:SkinManagerExtension ThemeName=MaterialLight}"
        mc:Ignorable="d"
        Title="Thêm người dùng mới" 
        Height="700" 
        Width="900"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- Button Style -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#4a7c2c"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6"
                                Padding="20,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3d6624"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.6"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="20,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F5F5F5"/>
                    <Setter Property="BorderBrush" Value="#999999"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="White" 
            CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect Color="Black" 
                            Direction="270" 
                            ShadowDepth="3" 
                            Opacity="0.3" 
                            BlurRadius="10"/>
        </Border.Effect>
        <Grid IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" 
                    Background="#4a7c2c"
                    CornerRadius="12,12,0,0"
                    Padding="30,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                              Text="👤"
                              FontSize="28"
                              VerticalAlignment="Center"
                              Margin="0,0,15,0"/>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Thêm người dùng mới" 
                                  FontSize="22" 
                                  FontWeight="Bold"
                                  Foreground="White"/>
                        <TextBlock Text="Điền đầy đủ thông tin để tạo tài khoản mới" 
                                  FontSize="13" 
                                  Foreground="#E8F5E9"
                                  Margin="0,5,0,0"/>
                    </StackPanel>

                    <Button Grid.Column="2"
                            x:Name="btnClose"
                            Content="✕"
                            Width="40"
                            Height="40"
                            Background="Transparent"
                            Foreground="White"
                            FontSize="20"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand"
                            VerticalAlignment="Center"
                            Click="btnClose_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" 
                                                   CornerRadius="20">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#558B2F"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" 
                         VerticalScrollBarVisibility="Auto"
                         Padding="40,30">
                <StackPanel>
                    <!-- Thông tin đăng nhập -->
                    <TextBlock Text="Thông tin đăng nhập" 
                              FontSize="16" 
                              FontWeight="Bold"
                              Foreground="#333333"
                              Margin="0,0,0,20"/>

                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <syncfusion:SfTextInputLayout 
                            Grid.Column="0"
                            Hint="Tên đăng nhập *"
                            HelperText="Tên đăng nhập để truy cập hệ thống"
                            ContainerType="Outlined"
                            OutlineCornerRadius="6">
                            <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                    FontSize="14"
                                    Padding="12"/>
                        </syncfusion:SfTextInputLayout>

                        <syncfusion:SfTextInputLayout 
                            Grid.Column="2"
                            Hint="Mật khẩu *"
                            HelperText="Mật khẩu tối thiểu 6 ký tự"
                            ContainerType="Outlined"
                            OutlineCornerRadius="6">
                            <PasswordBox x:Name="txtPassword"
                                        FontSize="14"
                                        Padding="12"
                                        PasswordChanged="txtPassword_PasswordChanged"/>
                        </syncfusion:SfTextInputLayout>
                    </Grid>

                    <!-- Thông tin cá nhân -->
                    <TextBlock Text="Thông tin cá nhân" 
                              FontSize="16" 
                              FontWeight="Bold"
                              Foreground="#333333"
                              Margin="0,20,0,20"/>

                    <syncfusion:SfTextInputLayout 
                        Hint="Họ và tên *"
                        HelperText="Họ tên đầy đủ của người dùng"
                        ContainerType="Outlined"
                        OutlineCornerRadius="6"
                        Margin="0,0,0,20">
                        <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"
                                FontSize="14"
                                Padding="12"/>
                    </syncfusion:SfTextInputLayout>

                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <syncfusion:SfTextInputLayout 
                            Grid.Column="0"
                            Hint="Email *"
                            HelperText="Địa chỉ email liên hệ"
                            ContainerType="Outlined"
                            OutlineCornerRadius="6">
                            <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                    FontSize="14"
                                    Padding="12"/>
                        </syncfusion:SfTextInputLayout>

                        <syncfusion:SfTextInputLayout 
                            Grid.Column="2"
                            Hint="Số điện thoại *"
                            HelperText="Số điện thoại liên hệ"
                            ContainerType="Outlined"
                            OutlineCornerRadius="6">
                            <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                                    FontSize="14"
                                    Padding="12"/>
                        </syncfusion:SfTextInputLayout>
                    </Grid>

                    <!-- Thông tin công tác -->
                    <TextBlock Text="Thông tin công tác" 
                              FontSize="16" 
                              FontWeight="Bold"
                              Foreground="#333333"
                              Margin="0,20,0,20"/>

                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <syncfusion:SfTextInputLayout 
                            Grid.Column="0"
                            Hint="Đơn vị *"
                            HelperText="Đơn vị công tác"
                            ContainerType="Outlined"
                            OutlineCornerRadius="6">
                            <ComboBox ItemsSource="{Binding Departments}"
                                     SelectedItem="{Binding SelectedDepartment}"
                                     FontSize="14"
                                     Padding="12"
                                     BorderThickness="0"
                                     Background="Transparent"/>
                        </syncfusion:SfTextInputLayout>

                        <syncfusion:SfTextInputLayout 
                            Grid.Column="2"
                            Hint="Chức vụ *"
                            HelperText="Chức vụ hiện tại"
                            ContainerType="Outlined"
                            OutlineCornerRadius="6">
                            <TextBox Text="{Binding Position, UpdateSourceTrigger=PropertyChanged}"
                                    FontSize="14"
                                    Padding="12"/>
                        </syncfusion:SfTextInputLayout>
                    </Grid>

                    <!-- Phân quyền -->
                    <TextBlock Text="Phân quyền và trạng thái" 
                              FontSize="16" 
                              FontWeight="Bold"
                              Foreground="#333333"
                              Margin="0,20,0,20"/>

                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <syncfusion:SfTextInputLayout 
                            Grid.Column="0"
                            Hint="Vai trò *"
                            HelperText="Quyền truy cập hệ thống"
                            ContainerType="Outlined"
                            OutlineCornerRadius="6">
                            <ComboBox ItemsSource="{Binding Roles}"
                                     SelectedItem="{Binding SelectedRole}"
                                     FontSize="14"
                                     Padding="12"
                                     BorderThickness="0"
                                     Background="Transparent"/>
                        </syncfusion:SfTextInputLayout>

                        <syncfusion:SfTextInputLayout 
                            Grid.Column="2"
                            Hint="Trạng thái *"
                            HelperText="Trạng thái tài khoản"
                            ContainerType="Outlined"
                            OutlineCornerRadius="6">
                            <ComboBox ItemsSource="{Binding Statuses}"
                                     SelectedItem="{Binding SelectedStatus}"
                                     FontSize="14"
                                     Padding="12"
                                     BorderThickness="0"
                                     Background="Transparent"/>
                        </syncfusion:SfTextInputLayout>
                    </Grid>

                    <!-- Ghi chú -->
                    <syncfusion:SfTextInputLayout 
                        Hint="Ghi chú"
                        HelperText="Thông tin bổ sung (không bắt buộc)"
                        ContainerType="Outlined"
                        OutlineCornerRadius="6">
                        <TextBox Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}"
                                FontSize="14"
                                Padding="12"
                                TextWrapping="Wrap"
                                AcceptsReturn="True"
                                Height="80"
                                VerticalScrollBarVisibility="Auto"/>
                    </syncfusion:SfTextInputLayout>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" 
                    Background="#F5F5F5"
                    CornerRadius="0,0,12,12"
                    Padding="40,20"
                    BorderBrush="#E0E0E0"
                    BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                              Text="* Trường bắt buộc nhập"
                              FontSize="12"
                              Foreground="#999999"
                              VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1" 
                               Orientation="Horizontal">
                        <Button Content="Hủy bỏ"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,0,10,0"
                                Command="{Binding CancelCommand}"/>
                        
                        <Button Content="💾 Lưu"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding SaveCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Loading Overlay -->
            <Grid Grid.RowSpan="3" 
                  Background="#80000000"
                  Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Border Background="White"
                       CornerRadius="8"
                       Padding="30"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="⏳" 
                                  FontSize="48" 
                                  HorizontalAlignment="Center"
                                  Margin="0,0,0,15"/>
                        <TextBlock Text="Đang xử lý..." 
                                  FontSize="16" 
                                  FontWeight="SemiBold"
                                  Foreground="#333333"
                                  HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>

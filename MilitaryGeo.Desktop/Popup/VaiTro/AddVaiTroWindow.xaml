<Window x:Class="MilitaryGeo.Desktop.Popup.VaiTro.AddVaiTroWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
        Title="Thong tin vai tro"
        Height="700" 
        Width="900"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#4a7c2c"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#5a8c3c"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D0D0D0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" 
                Background="White" 
                CornerRadius="8" 
                Padding="20"
                Margin="0,0,0,15">
            <TextBlock Text="THONG TIN VAI TRO" 
                      FontSize="20" 
                      FontWeight="Bold"
                      Foreground="#2d5a1a"/>
        </Border>

        <!-- Form Content -->
        <ScrollViewer Grid.Row="1" 
                     VerticalScrollBarVisibility="Auto"
                     Margin="0,0,0,15">
            <Border Background="White" 
                    CornerRadius="8" 
                    Padding="25">
                <StackPanel>
                    <!-- Basic Information -->
                    <TextBlock Text="Thong tin co ban" 
                              FontSize="16" 
                              FontWeight="Bold"
                              Foreground="#4a7c2c"
                              Margin="0,0,0,15"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="15"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="15"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="15"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Ma vai tro -->
                        <StackPanel Grid.Row="0" Grid.Column="0">
                            <TextBlock Text="Ma vai tro *" Style="{StaticResource FormLabel}"/>
                            <TextBox Text="{Binding MaVaiTro, UpdateSourceTrigger=PropertyChanged}"
                                    FontSize="14"
                                    Padding="10,8"
                                    CharacterCasing="Upper"/>
                        </StackPanel>

                        <!-- Ten vai tro -->
                        <StackPanel Grid.Row="0" Grid.Column="2">
                            <TextBlock Text="Ten vai tro *" Style="{StaticResource FormLabel}"/>
                            <TextBox Text="{Binding TenVaiTro, UpdateSourceTrigger=PropertyChanged}"
                                    FontSize="14"
                                    Padding="10,8"/>
                        </StackPanel>

                        <!-- Thu tu -->
                        <StackPanel Grid.Row="2" Grid.Column="0">
                            <TextBlock Text="Thu tu" Style="{StaticResource FormLabel}"/>
                            <TextBox Text="{Binding ThuTu, UpdateSourceTrigger=PropertyChanged}"
                                    FontSize="14"
                                    Padding="10,8"/>
                        </StackPanel>

                        <!-- Trang thai -->
                        <StackPanel Grid.Row="2" Grid.Column="2">
                            <TextBlock Text="Trang thai" Style="{StaticResource FormLabel}"/>
                            <CheckBox Content="Kich hoat" 
                                     IsChecked="{Binding IsActive}"
                                     FontSize="14"
                                     Margin="0,10,0,0"/>
                        </StackPanel>

                        <!-- Mo ta -->
                        <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3">
                            <TextBlock Text="Mo ta" Style="{StaticResource FormLabel}"/>
                            <TextBox Text="{Binding MoTa, UpdateSourceTrigger=PropertyChanged}"
                                    FontSize="14"
                                    Padding="10,8"
                                    Height="80"
                                    TextWrapping="Wrap"
                                    AcceptsReturn="True"
                                    VerticalScrollBarVisibility="Auto"/>
                        </StackPanel>

                        <!-- Ghi chu -->
                        <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="3">
                            <TextBlock Text="Ghi chu" Style="{StaticResource FormLabel}"/>
                            <TextBox Text="{Binding GhiChu, UpdateSourceTrigger=PropertyChanged}"
                                    FontSize="14"
                                    Padding="10,8"
                                    Height="60"
                                    TextWrapping="Wrap"
                                    AcceptsReturn="True"
                                    VerticalScrollBarVisibility="Auto"/>
                        </StackPanel>
                    </Grid>

                    <!-- Permissions Section -->
                    <Border BorderBrush="#E0E0E0" 
                           BorderThickness="0,1,0,0"
                           Margin="0,20,0,0"
                           Padding="0,20,0,0">
                        <StackPanel>
                            <TextBlock Text="Phan quyen chuc nang" 
                                      FontSize="16" 
                                      FontWeight="Bold"
                                      Foreground="#4a7c2c"
                                      Margin="0,0,0,15"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <CheckBox Grid.Row="0" Grid.Column="0"
                                         Content="Xem Dashboard" 
                                         IsChecked="{Binding QuyenDashboard}"
                                         FontSize="14"
                                         Margin="0,5"/>

                                <CheckBox Grid.Row="0" Grid.Column="1"
                                         Content="Quan ly ban do" 
                                         IsChecked="{Binding QuyenBanDo}"
                                         FontSize="14"
                                         Margin="0,5"/>

                                <CheckBox Grid.Row="2" Grid.Column="0"
                                         Content="Quan ly du lieu" 
                                         IsChecked="{Binding QuyenDuLieu}"
                                         FontSize="14"
                                         Margin="0,5"/>

                                <CheckBox Grid.Row="2" Grid.Column="1"
                                         Content="Quan ly nguoi dung" 
                                         IsChecked="{Binding QuyenNguoiDung}"
                                         FontSize="14"
                                         Margin="0,5"/>

                                <CheckBox Grid.Row="4" Grid.Column="0"
                                         Content="Quan ly vai tro" 
                                         IsChecked="{Binding QuyenVaiTro}"
                                         FontSize="14"
                                         Margin="0,5"/>

                                <CheckBox Grid.Row="4" Grid.Column="1"
                                         Content="Cai dat he thong" 
                                         IsChecked="{Binding QuyenCaiDat}"
                                         FontSize="14"
                                         Margin="0,5"/>

                                <CheckBox Grid.Row="6" Grid.Column="0"
                                         Content="Bao cao" 
                                         IsChecked="{Binding QuyenBaoCao}"
                                         FontSize="14"
                                         Margin="0,5"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- Footer Buttons -->
        <Border Grid.Row="2" 
                Background="White" 
                CornerRadius="8" 
                Padding="20">
            <StackPanel Orientation="Horizontal" 
                       HorizontalAlignment="Right">
                <Button Content="Luu" 
                       Style="{StaticResource PrimaryButton}"
                       Command="{Binding SaveCommand}"
                       Click="SaveButton_Click"
                       Margin="0,0,10,0"/>
                <Button Content="Huy" 
                       Style="{StaticResource SecondaryButton}"
                       Click="CancelButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>

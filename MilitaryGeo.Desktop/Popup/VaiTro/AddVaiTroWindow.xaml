<Window x:Class="MilitaryGeo.Desktop.Popup.VaiTro.AddVaiTroWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
        xmlns:skin="clr-namespace:Syncfusion.SfSkinManager;assembly=Syncfusion.SfSkinManager.WPF"
        skin:SfSkinManager.Theme="{skin:SkinManagerExtension ThemeName=MaterialLight}"
        mc:Ignorable="d"
        Title="Quan ly vai tro"
        Height="700" Width="900"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        FontFamily="Segoe UI">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/MilitaryGeo.Desktop;component/Resources/AppStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <!-- Khong can Window.Resources vi tat ca styles duoc lay tu AppStyles.xaml -->

    <Border Style="{StaticResource DialogWindow}" Margin="15">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Style="{StaticResource TitleBar}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Icon -->
                    <Ellipse Grid.Column="0" Width="40" Height="40" Fill="#3D6D34"
                             VerticalAlignment="Center" Margin="0,0,15,0">
                        <Ellipse.Effect>
                            <DropShadowEffect Color="Black" Opacity="0.3" BlurRadius="8" ShadowDepth="2"/>
                        </Ellipse.Effect>
                    </Ellipse>
                    <TextBlock Grid.Column="0" Text="R" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource TextLight}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Margin="0,0,15,0"/>

                    <!-- Title Text -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Thông tin vai trò" FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource TextLight}"/>
                        <TextBlock Text="Quản lý quyền truy cập hệ thống"
                                   FontSize="12" Foreground="#E8F5E9" Opacity="0.85" Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Close Button -->
                    <Button Grid.Column="2" Content="&#10005;"
                            Foreground="{StaticResource TextLight}" Background="Transparent"
                            BorderThickness="0" FontSize="18" Cursor="Hand"
                            Click="CancelButton_Click" Opacity="0.75"
                            Width="40" Height="40">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="20">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="1"/>
                                        <Setter Property="Background" Value="{StaticResource DangerRed}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- Form Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="35,25">
                <StackPanel>

                    <!-- Section: Thong tin co ban -->
                    <Border Style="{StaticResource FormCard}">
                        <StackPanel>
                            <TextBlock Text="Thông tin cơ bản" Style="{StaticResource SectionHeader}"/>

                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="25"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <syncfusion:SfTextInputLayout Grid.Column="0" Hint="Mã vai trò *"
                                    ContainerType="Outlined" OutlineCornerRadius="6">
                                    <TextBox Text="{Binding MaVaiTro, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="14" Padding="10" CharacterCasing="Upper"/>
                                </syncfusion:SfTextInputLayout>

                                <syncfusion:SfTextInputLayout Grid.Column="2" Hint="Tên vai trò *"
                                    ContainerType="Outlined" OutlineCornerRadius="6">
                                    <TextBox Text="{Binding TenVaiTro, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="14" Padding="10"/>
                                </syncfusion:SfTextInputLayout>
                            </Grid>

                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="25"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <syncfusion:SfTextInputLayout Grid.Column="0" Hint="Thứ tự hiển thị"
                                    ContainerType="Outlined" OutlineCornerRadius="6">
                                    <TextBox Text="{Binding ThuTu, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="14" Padding="10"/>
                                </syncfusion:SfTextInputLayout>

                                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="0,8,0,0">
                                    <TextBlock Text="Trạng thái" Style="{StaticResource FormLabel}"/>
                                    <CheckBox Content="Kích hoạt vai trò"
                                              IsChecked="{Binding IsActive}"
                                              Style="{StaticResource ModernCheckBox}"/>
                                </StackPanel>
                            </Grid>

                            <syncfusion:SfTextInputLayout Hint="Mô tả" ContainerType="Outlined"
                                OutlineCornerRadius="6" Margin="0,0,0,20">
                                <TextBox Text="{Binding MoTa, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="14" Padding="10" Height="80"
                                         TextWrapping="Wrap" AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"/>
                            </syncfusion:SfTextInputLayout>

                            <syncfusion:SfTextInputLayout Hint="Ghi chú (tùy chọn)" ContainerType="Outlined"
                                OutlineCornerRadius="6">
                                <TextBox Text="{Binding GhiChu, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="14" Padding="10" Height="60"
                                         TextWrapping="Wrap" AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"/>
                            </syncfusion:SfTextInputLayout>
                        </StackPanel>
                    </Border>

                    <!-- Section: Phan quyen -->
                    <Border Style="{StaticResource FormCard}">
                        <StackPanel>
                            <TextBlock Text="Phân quyền chức năng" Style="{StaticResource SectionHeader}"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource PermissionCard}" Margin="0,0,6,0">
                                    <CheckBox Content="Xem Dashboard"
                                              IsChecked="{Binding QuyenDashboard}"
                                              Style="{StaticResource ModernCheckBox}"/>
                                </Border>
                                <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource PermissionCard}" Margin="6,0,0,0">
                                    <CheckBox Content="Quản lý bản đồ"
                                              IsChecked="{Binding QuyenBanDo}"
                                              Style="{StaticResource ModernCheckBox}"/>
                                </Border>

                                <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource PermissionCard}" Margin="0,0,6,0">
                                    <CheckBox Content="Quản lý dữ liệu"
                                              IsChecked="{Binding QuyenDuLieu}"
                                              Style="{StaticResource ModernCheckBox}"/>
                                </Border>
                                <Border Grid.Row="2" Grid.Column="2" Style="{StaticResource PermissionCard}" Margin="6,0,0,0">
                                    <CheckBox Content="Quản lý người dùng"
                                              IsChecked="{Binding QuyenNguoiDung}"
                                              Style="{StaticResource ModernCheckBox}"/>
                                </Border>

                                <Border Grid.Row="4" Grid.Column="0" Style="{StaticResource PermissionCard}" Margin="0,0,6,0">
                                    <CheckBox Content="Quản lý vai trò"
                                              IsChecked="{Binding QuyenVaiTro}"
                                              Style="{StaticResource ModernCheckBox}"/>
                                </Border>
                                <Border Grid.Row="4" Grid.Column="2" Style="{StaticResource PermissionCard}" Margin="6,0,0,0">
                                    <CheckBox Content="Cài đặt hệ thống"
                                              IsChecked="{Binding QuyenCaiDat}"
                                              Style="{StaticResource ModernCheckBox}"/>
                                </Border>

                                <Border Grid.Row="6" Grid.Column="0" Style="{StaticResource PermissionCard}" Margin="0,0,6,0">
                                    <CheckBox Content="Báo cáo và thống kê"
                                              IsChecked="{Binding QuyenBaoCao}"
                                              Style="{StaticResource ModernCheckBox}"/>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Style="{StaticResource FooterBar}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Hint text -->
					<ContentControl Grid.Column="0"
                        Content="Vui lòng kiểm tra kỹ các trường bắt buộc (*)"
                        Style="{StaticResource ModernHintText}"/>

                    <!-- Action Buttons -->
					<StackPanel Grid.Column="1" Orientation="Horizontal">

						<Button Content="HỦY BỎ"
								Style="{StaticResource ModernSecondaryBtn}"
								Tag="{StaticResource IconCancel}"
								Click="CancelButton_Click"
								Margin="0,0,12,0"/>

						<Button Content="LƯU"
								Style="{StaticResource ModernPrimaryBtn}"
								Tag="{StaticResource IconSave}"
								Command="{Binding SaveCommand}"
								Click="SaveButton_Click"/>

					</StackPanel>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
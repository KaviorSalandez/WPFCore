<UserControl x:Class="MilitaryGeo.Desktop.UserControls.Dashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MilitaryGeo.Desktop.UserControls"
             xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200"
             Background="#F5F5F5">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <!-- Welcome Section -->
            <Border Background="White"
                   CornerRadius="8"
                   Padding="30"
                   Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Chào mừng trở lại!" 
                              FontSize="28" 
                              FontWeight="Bold"
                              Foreground="#333333"
                              Margin="0,0,0,10"/>
                    <TextBlock Text="Hệ thống quản lý dữ liệu địa lý quân sự" 
                              FontSize="14" 
                              Foreground="#666666"/>
                </StackPanel>
            </Border>

            <!-- Statistics Cards -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Card 1: Total Maps -->
                <Border Grid.Column="0" 
                       Background="White"
                       CornerRadius="8"
                       Padding="20"
                       Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="🗺️" FontSize="32" Margin="0,0,0,10"/>
                        <TextBlock Text="Tổng bản đồ" 
                                  FontSize="13" 
                                  Foreground="#666666"
                                  Margin="0,0,0,5"/>
                        <TextBlock Text="1,234" 
                                  FontSize="28" 
                                  FontWeight="Bold"
                                  Foreground="#4a7c2c"/>
                    </StackPanel>
                </Border>

                <!-- Card 2: Data Files -->
                <Border Grid.Column="1" 
                       Background="White"
                       CornerRadius="8"
                       Padding="20"
                       Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="📁" FontSize="32" Margin="0,0,0,10"/>
                        <TextBlock Text="Tệp dữ liệu" 
                                  FontSize="13" 
                                  Foreground="#666666"
                                  Margin="0,0,0,5"/>
                        <TextBlock Text="5,678" 
                                  FontSize="28" 
                                  FontWeight="Bold"
                                  Foreground="#2196F3"/>
                    </StackPanel>
                </Border>

                <!-- Card 3: Coordinates -->
                <Border Grid.Column="2" 
                       Background="White"
                       CornerRadius="8"
                       Padding="20"
                       Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="📍" FontSize="32" Margin="0,0,0,10"/>
                        <TextBlock Text="Tọa độ" 
                                  FontSize="13" 
                                  Foreground="#666666"
                                  Margin="0,0,0,5"/>
                        <TextBlock Text="12,345" 
                                  FontSize="28" 
                                  FontWeight="Bold"
                                  Foreground="#FF9800"/>
                    </StackPanel>
                </Border>

                <!-- Card 4: Users -->
                <Border Grid.Column="3" 
                       Background="White"
                       CornerRadius="8"
                       Padding="20">
                    <StackPanel>
                        <TextBlock Text="👥" FontSize="32" Margin="0,0,0,10"/>
                        <TextBlock Text="Người dùng" 
                                  FontSize="13" 
                                  Foreground="#666666"
                                  Margin="0,0,0,5"/>
                        <TextBlock Text="89" 
                                  FontSize="28" 
                                  FontWeight="Bold"
                                  Foreground="#9C27B0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Recent Activity -->
            <Border Background="White"
                   CornerRadius="8"
                   Padding="20">
                <StackPanel>
                    <TextBlock Text="Hoạt động gần đây" 
                              FontSize="18" 
                              FontWeight="Bold"
                              Foreground="#333333"
                              Margin="0,0,0,20"/>

                    <syncfusion:SfDataGrid x:Name="gridRecentActivity"
                                          AutoGenerateColumns="False"
                                          ColumnSizer="Star"
                                          GridLinesVisibility="Horizontal"
                                          HeaderRowHeight="40"
                                          RowHeight="45">
                        <syncfusion:SfDataGrid.Columns>
                            <syncfusion:GridTextColumn HeaderText="Thời gian" 
                                                      MappingName="Time" 
                                                      Width="150"/>
                            <syncfusion:GridTextColumn HeaderText="Hoạt động" 
                                                      MappingName="Activity"/>
                            <syncfusion:GridTextColumn HeaderText="Người thực hiện" 
                                                      MappingName="User" 
                                                      Width="200"/>
                            <syncfusion:GridTextColumn HeaderText="Trạng thái" 
                                                      MappingName="Status" 
                                                      Width="150"/>
                        </syncfusion:SfDataGrid.Columns>
                    </syncfusion:SfDataGrid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>

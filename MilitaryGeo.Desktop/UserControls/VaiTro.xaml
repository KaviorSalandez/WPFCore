<UserControl x:Class="MilitaryGeo.Desktop.UserControls.VaiTro"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:MilitaryGeo.Desktop.UserControls"
             xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1200"
             Background="#F5F5F5"
             >

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <Border Grid.Row="0" 
                Background="White"
                CornerRadius="8"
                Padding="25"
                Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Quản lý vai trò" 
                              FontSize="24" 
                              FontWeight="Bold"
                              Foreground="#333333"
                              Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding TotalRolesText}"
                              FontSize="13" 
                              Foreground="#666666"/>
                </StackPanel>

                <StackPanel Grid.Column="1" 
                           Orientation="Horizontal"
                           VerticalAlignment="Center">
                    <Button Content="Xuất Excel"
            Style="{StaticResource ModernExportBtn}"
            Tag="{StaticResource IconExport}"
            Command="{Binding ExportCommand}"
            Margin="0,0,12,0"/>
                    <Button Content="Thêm vai trò"
                            Style="{StaticResource ModernPrimaryBtn}"
                            Tag="{StaticResource IconAdd}"
                            Command="{Binding AddCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Data Grid Section -->
        <Border Grid.Row="1" 
                Background="White"
                CornerRadius="8"
                Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Search and Filter -->
                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                           Background="#F5F5F5"
                           CornerRadius="6"
                           Height="40"
                           Width="350"
                           Margin="0,0,15,0">
                        <Grid>
                            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                    FontSize="13"
                                    Foreground="#333333"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    VerticalAlignment="Center"
                                    Padding="15,0,40,0"/>
                            <TextBlock Text="🔍" 
                                      FontSize="14"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Center"
                                      Margin="0,0,12,0"
                                      IsHitTestVisible="False"
                                      Opacity="0.5"/>
                        </Grid>
                    </Border>

                    <Button Grid.Column="2"
                        Content="LÀM MỚI"
                        Style="{StaticResource ModernSecondaryBtn}"
                        Tag="{StaticResource IconRefresh}"
                        Command="{Binding RefreshCommand}"
                        Height="40"
                        Margin="8,0,0,0"/>
                </Grid>

                <!-- Role Data Grid -->
                <syncfusion:SfDataGrid Grid.Row="1"
                                      ItemsSource="{Binding PagedRoles}"
                                      AutoGenerateColumns="False"
                                      ColumnSizer="Auto"
                                      GridLinesVisibility="Horizontal"
                                      HeaderRowHeight="45"
                                      RowHeight="50"
                                      SelectionMode="None"
                                      AllowEditing="False"
                                      AllowSorting="False"
                                      AllowFiltering="False">
                    <syncfusion:SfDataGrid.Columns>
                        <syncfusion:GridTextColumn HeaderText="ID" 
                                                  MappingName="Id" 
                                                  Width="70"
                                                  TextAlignment="Center"/>
                        <syncfusion:GridTextColumn HeaderText="Mã vai trò" 
                                                  MappingName="MaVaiTro" 
                                                  Width="250"/>
                        <syncfusion:GridTextColumn HeaderText="Tên vai trò" 
                                                  MappingName="TenVaiTro" 
                                                  Width="300"/>
                        <syncfusion:GridTextColumn HeaderText="Mô tả" 
                                                  MappingName="MoTa" 
                                                  Width="500"/>
                        <syncfusion:GridTextColumn HeaderText="Thứ tự" 
                                                  MappingName="ThuTu" 
                                                  Width="90"
                                                  TextAlignment="Center"/>
                        <syncfusion:GridTemplateColumn HeaderText="Ngày tạo" 
                                                      MappingName="CreatedDate" Width="150"
                                                      >
                            <syncfusion:GridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding CreatedDate, StringFormat='dd/MM/yyyy'}"
                                              VerticalAlignment="Center"
                                              Margin="10,0"/>
                                </DataTemplate>
                            </syncfusion:GridTemplateColumn.CellTemplate>
                        </syncfusion:GridTemplateColumn>
                        <syncfusion:GridTemplateColumn HeaderText="Trạng thái" 
                                                      MappingName="IsActive"
                                                      Width="110">
                            <syncfusion:GridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="12"
                                           Padding="8,4"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Background" Value="#E8F5E9"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                        <Setter Property="Background" Value="#FFEBEE"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock FontSize="12"
                                                  FontWeight="SemiBold"
                                                  HorizontalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Text" Value="Hoạt động"/>
                                                            <Setter Property="Foreground" Value="#4CAF50"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                            <Setter Property="Text" Value="Tắt"/>
                                                            <Setter Property="Foreground" Value="#F44336"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </syncfusion:GridTemplateColumn.CellTemplate>
                        </syncfusion:GridTemplateColumn>
                        <syncfusion:GridTemplateColumn HeaderText="Thao tác" 
                                                      Width="120"
                                                      TextAlignment="Center">
                            <syncfusion:GridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                                        <Button Style="{StaticResource GridActionButton}"
                                            Background="#E3F2FD" 
                                            Foreground="{StaticResource InfoBlue}"
                                            Tag="{StaticResource IconEdit}"
                                            ToolTip="Chỉnh sửa"
                                            Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                        <Button Style="{StaticResource GridActionButton}"
                                            Background="#FFEBEE" 
                                            Foreground="{StaticResource DangerRed}"
                                            Tag="{StaticResource IconDelete}"
                                            ToolTip="Xóa vai trò"
                                            Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </syncfusion:GridTemplateColumn.CellTemplate>
                        </syncfusion:GridTemplateColumn>
                    </syncfusion:SfDataGrid.Columns>
                </syncfusion:SfDataGrid>
            </Grid>
        </Border>

        <!-- Pagination Section -->
        <Border Grid.Row="2" Style="{StaticResource FormCard}" Margin="0,20,0,0" Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Hiển thị" Style="{StaticResource SubtitleText}" VerticalAlignment="Center"/>
                    <ComboBox Style="{StaticResource ModernComboBox}" 
                      Width="80" Margin="10,0"
                      ItemsSource="{Binding PageSizes}"
                      SelectedItem="{Binding PageSize}"/>
                    <TextBlock Text="dòng / trang" Style="{StaticResource SubtitleText}" VerticalAlignment="Center"/>
                </StackPanel>

                <ContentControl Grid.Column="1" 
                        Content="{Binding PageInfo}" 
                        Style="{StaticResource ModernHintText}" 
                        HorizontalAlignment="Center"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Style="{StaticResource PaginationBtn}"
                    Tag="{StaticResource IconFirstPage}"
                    Command="{Binding FirstPageCommand}"
                    IsEnabled="{Binding CanGoToPreviousPage}"
                    ToolTip="Trang đầu"/>

                    <Button Style="{StaticResource PaginationBtn}"
                    Tag="{StaticResource IconPrev}"
                    Command="{Binding PreviousPageCommand}"
                    IsEnabled="{Binding CanGoToPreviousPage}"
                    ToolTip="Trang trước"/>

                    <TextBox Style="{StaticResource PaginationInput}"
                     Text="{Binding CurrentPage, UpdateSourceTrigger=PropertyChanged}"
                     Margin="8,0"/>

                    <TextBlock Text="/" VerticalAlignment="Center" Foreground="{StaticResource TextMuted}" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding TotalPages}" VerticalAlignment="Center" FontWeight="Bold" Foreground="{StaticResource TextDark}" Margin="0,0,8,0"/>

                    <Button Style="{StaticResource PaginationBtn}"
                    Tag="{StaticResource IconNext}"
                    Command="{Binding NextPageCommand}"
                    IsEnabled="{Binding CanGoToNextPage}"
                    ToolTip="Trang sau"/>

                    <Button Style="{StaticResource PaginationBtn}"
                    Tag="{StaticResource IconLastPage}"
                    Command="{Binding LastPageCommand}"
                    IsEnabled="{Binding CanGoToNextPage}"
                    ToolTip="Trang cuối"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>

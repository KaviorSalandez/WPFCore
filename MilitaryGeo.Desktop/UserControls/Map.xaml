<UserControl x:Class="MilitaryGeo.Desktop.UserControls.Map"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MilitaryGeo.Desktop.UserControls"
             xmlns:vm="clr-namespace:MilitaryGeo.Desktop.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200"
             Background="#F5F5F5">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <Border Grid.Row="0" 
                Background="White"
                CornerRadius="12"
                Padding="25"
                Margin="0,0,0,20">
            <Border.Effect>
                <DropShadowEffect Color="Black" Direction="270" ShadowDepth="2" Opacity="0.1" BlurRadius="8"/>
            </Border.Effect>
            
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="🗺️ Quản lý bản đồ GIS" 
                              FontSize="24" 
                              FontWeight="Bold"
                              Foreground="#333333"
                              Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding CurrentCoordinates}"
                              FontSize="13" 
                              Foreground="#666666"/>
                </StackPanel>

                <StackPanel Grid.Column="1" 
                           Orientation="Horizontal"
                           VerticalAlignment="Center">
                    <TextBlock Text="Total Markers: "
                              FontSize="13"
                              Foreground="#666666"
                              VerticalAlignment="Center"
                              Margin="0,0,5,0"/>
                    <TextBlock Text="{Binding TotalMarkers}"
                              FontSize="20"
                              FontWeight="Bold"
                              Foreground="#4a7c2c"
                              VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel - Controls -->
            <Border Grid.Column="0" 
                    Background="White"
                    CornerRadius="12"
                    Padding="20">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Direction="270" ShadowDepth="2" Opacity="0.1" BlurRadius="8"/>
                </Border.Effect>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- Search Section -->
                        <TextBlock Text="🔍 Tìm kiếm vị trí" 
                                  FontSize="16" 
                                  FontWeight="Bold"
                                  Foreground="#333333"
                                  Margin="0,0,0,15"/>

                        <Grid Margin="0,0,0,20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBox Grid.Row="0"
                                    Text="{Binding SearchLocation, UpdateSourceTrigger=PropertyChanged}"
                                    FontSize="13"
                                    Padding="12"
                                    Margin="0,0,0,10"
                                    BorderBrush="#CCCCCC"
                                    BorderThickness="1"/>

                            <Button Grid.Row="1"
                                   Content="🔎 Tìm kiếm"
                                   Background="#4a7c2c"
                                   Foreground="White"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Padding="0,10"
                                   BorderThickness="0"
                                   Cursor="Hand"
                                   Command="{Binding SearchLocationCommand}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                           CornerRadius="6"
                                                           Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#3d6624"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>

                        <!-- Map Style -->
                        <TextBlock Text="🎨 Kiểu bản đồ" 
                                  FontSize="16" 
                                  FontWeight="Bold"
                                  Foreground="#333333"
                                  Margin="0,0,0,15"/>

                        <ComboBox ItemsSource="{Binding MapStyles}"
                                 SelectedItem="{Binding MapStyle}"
                                 FontSize="13"
                                 Padding="12"
                                 Margin="0,0,0,20"/>

                        <!-- Zoom Controls -->
                        <TextBlock Text="🔍 Mức phóng to" 
                                  FontSize="16" 
                                  FontWeight="Bold"
                                  Foreground="#333333"
                                  Margin="0,0,0,15"/>

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0"
                                   Content="➖"
                                   Width="40"
                                   Height="40"
                                   FontSize="18"
                                   Margin="0,0,5,0"
                                   Command="{Binding ZoomOutCommand}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#F5F5F5"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#E0E0E0"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <TextBlock Grid.Column="1"
                                      Text="{Binding ZoomLevel}"
                                      FontSize="20"
                                      FontWeight="Bold"
                                      Foreground="#4a7c2c"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>

                            <Button Grid.Column="2"
                                   Content="➕"
                                   Width="40"
                                   Height="40"
                                   FontSize="18"
                                   Margin="5,0,0,0"
                                   Command="{Binding ZoomInCommand}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#F5F5F5"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#E0E0E0"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>

                        <!-- Quick Actions -->
                        <TextBlock Text="⚡ Thao tác nhanh" 
                                  FontSize="16" 
                                  FontWeight="Bold"
                                  Foreground="#333333"
                                  Margin="0,0,0,15"/>

                        <Button Content="📍 Thêm Marker"
                               Margin="0,0,0,10"
                               Command="{Binding AddMarkerCommand}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#E3F2FD"/>
                                    <Setter Property="Foreground" Value="#2196F3"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="0,12"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#BBDEFB"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="📏 Đo khoảng cách"
                               Margin="0,0,0,10"
                               Command="{Binding MeasureDistanceCommand}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#FFF3E0"/>
                                    <Setter Property="Foreground" Value="#FF9800"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="0,12"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#FFE0B2"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="📐 Đo diện tích"
                               Margin="0,0,0,10"
                               Command="{Binding MeasureAreaCommand}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#F3E5F5"/>
                                    <Setter Property="Foreground" Value="#9C27B0"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="0,12"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#E1BEE7"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="🌍 Vị trí của tôi"
                               Margin="0,0,0,10"
                               Command="{Binding GetMyLocationCommand}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#E8F5E9"/>
                                    <Setter Property="Foreground" Value="#4CAF50"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="0,12"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#C8E6C9"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="🔄 Reset View"
                               Margin="0,0,0,20"
                               Command="{Binding ResetViewCommand}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#FFEBEE"/>
                                    <Setter Property="Foreground" Value="#F44336"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="0,12"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#FFCDD2"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Markers List -->
                        <TextBlock Text="📍 Danh sách Markers" 
                                  FontSize="16" 
                                  FontWeight="Bold"
                                  Foreground="#333333"
                                  Margin="0,0,0,15"/>

                        <ListBox ItemsSource="{Binding Markers}"
                                Height="250"
                                BorderBrush="#CCCCCC"
                                BorderThickness="1">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F5F5F5"
                                           CornerRadius="6"
                                           Padding="10"
                                           Margin="0,2">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0"
                                                      Text="{Binding Name}"
                                                      FontWeight="Bold"
                                                      FontSize="13"
                                                      Foreground="#333333"/>
                                            
                                            <TextBlock Grid.Row="1"
                                                      FontSize="11"
                                                      Foreground="#666666"
                                                      Margin="0,3,0,0">
                                                <Run Text="Type: "/><Run Text="{Binding Type}" FontWeight="SemiBold"/>
                                            </TextBlock>

                                            <TextBlock Grid.Row="2"
                                                      FontSize="10"
                                                      Foreground="#888888"
                                                      Margin="0,2,0,0">
                                                <Run Text="Lat: "/><Run Text="{Binding Latitude, StringFormat=F4}"/>
                                                <Run Text=" | Lon: "/><Run Text="{Binding Longitude, StringFormat=F4}"/>
                                            </TextBlock>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Button Content="🗑️ Xóa tất cả Markers"
                               Margin="0,10,0,0"
                               Command="{Binding ClearAllMarkersCommand}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#F44336"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="0,8"/>
                                    <Setter Property="BorderBrush" Value="#F44336"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" 
                                                       BorderBrush="{TemplateBinding BorderBrush}"
                                                       BorderThickness="{TemplateBinding BorderThickness}"
                                                       CornerRadius="6" 
                                                       Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#FFEBEE"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Right Panel - Map Display -->
            <Border Grid.Column="2" 
                    Background="White"
                    CornerRadius="12"
                    Padding="20">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Direction="270" ShadowDepth="2" Opacity="0.1" BlurRadius="8"/>
                </Border.Effect>

                <Grid>
                    <!-- Map Placeholder with Instructions -->
                    <Border BorderBrush="#4CAF50"
                           BorderThickness="2"
                           CornerRadius="8">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#E8F5E9" Offset="0"/>
                                <GradientStop Color="#C8E6C9" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="600">
                            <TextBlock Text="🗺️" 
                                      FontSize="64" 
                                      HorizontalAlignment="Center"
                                      Margin="0,0,0,20"/>
                            
                            <TextBlock Text="Khu vực hiển thị bản đồ ArcGIS" 
                                      FontSize="24" 
                                      FontWeight="Bold"
                                      Foreground="#2E7D32"
                                      HorizontalAlignment="Center"
                                      Margin="0,0,0,15"/>
                            
                            <Border Background="White"
                                   CornerRadius="8"
                                   Padding="20"
                                   Margin="0,10">
                                <StackPanel>
                                    <TextBlock Text="✅ Đã cấu hình:" 
                                              FontSize="14" 
                                              FontWeight="Bold"
                                              Foreground="#333333"
                                              Margin="0,0,0,10"/>
                                    
                                    <StackPanel Orientation="Horizontal" Margin="0,5">
                                        <TextBlock Text="• " FontSize="13" Foreground="#666666"/>
                                        <TextBlock Text="API Key: " FontSize="13" Foreground="#666666"/>
                                        <TextBlock Text="{Binding ArcGISApiKey, Mode=OneWay}" 
                                                  FontFamily="Consolas" 
                                                  FontSize="11" 
                                                  Foreground="#4CAF50"
                                                  FontWeight="SemiBold"
                                                  MaxWidth="400"
                                                  TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    
                                    <StackPanel Orientation="Horizontal" Margin="0,5">
                                        <TextBlock Text="• " FontSize="13" Foreground="#666666"/>
                                        <TextBlock Text="Tọa độ mặc định: " FontSize="13" Foreground="#666666"/>
                                        <TextBlock Text="Hà Nội, Việt Nam (21.0285°N, 105.8542°E)" 
                                                  FontSize="13" 
                                                  Foreground="#4CAF50"
                                                  FontWeight="SemiBold"/>
                                    </StackPanel>
                                    
                                    <StackPanel Orientation="Horizontal" Margin="0,5">
                                        <TextBlock Text="• " FontSize="13" Foreground="#666666"/>
                                        <TextBlock Text="Zoom level: " FontSize="13" Foreground="#666666"/>
                                        <TextBlock Text="{Binding ZoomLevel}" 
                                                  FontSize="13" 
                                                  Foreground="#4CAF50"
                                                  FontWeight="SemiBold"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            
                            <Border Background="#FFF3E0"
                                   BorderBrush="#FF9800"
                                   BorderThickness="2"
                                   CornerRadius="8"
                                   Padding="15"
                                   Margin="0,15">
                                <StackPanel>
                                    <TextBlock Text="📚 Hướng dẫn tích hợp ArcGIS Runtime:" 
                                              FontSize="14" 
                                              FontWeight="Bold"
                                              Foreground="#E65100"
                                              Margin="0,0,0,10"/>
                                    
                                    <TextBlock FontSize="12" Foreground="#666666" TextWrapping="Wrap" Margin="0,3">
                                        <Run Text="1. Package đã cài: "/><Run Text="Esri.ArcGISRuntime.WPF v200.8.1" FontWeight="Bold" Foreground="#4CAF50"/>
                                    </TextBlock>
                                    
                                    <TextBlock FontSize="12" Foreground="#666666" TextWrapping="Wrap" Margin="0,3">
                                        <Run Text="2. Xem tài liệu ArcGIS tại: "/><Run Text="developers.arcgis.com" FontFamily="Consolas" Foreground="#1976D2" FontWeight="Bold"/>
                                    </TextBlock>
                                    
                                    <TextBlock FontSize="12" Foreground="#666666" TextWrapping="Wrap" Margin="0,3">
                                        <Run Text="3. Thêm MapView control vào vùng này"/>
                                    </TextBlock>
                                    
                                    <TextBlock FontSize="12" Foreground="#666666" TextWrapping="Wrap" Margin="0,3">
                                        <Run Text="4. Khởi tạo với API Key đã có trong ViewModel"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                            
                            <TextBlock Text="Tất cả controls panel bên trái đã sẵn sàng và binding đầy đủ!" 
                                      FontSize="13" 
                                      Foreground="#666666"
                                      HorizontalAlignment="Center"
                                      Margin="0,15,0,0"
                                      FontStyle="Italic"
                                      TextWrapping="Wrap"
                                      TextAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Loading Overlay -->
                    <Border Background="#80000000"
                           Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="⏳" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="Đang tải bản đồ..." 
                                      FontSize="16" 
                                      Foreground="White"
                                      FontWeight="SemiBold"
                                      HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- Footer Section -->
        <Border Grid.Row="2" 
                Background="White"
                CornerRadius="12"
                Padding="20,15"
                Margin="0,20,0,0">
            <Border.Effect>
                <DropShadowEffect Color="Black" Direction="270" ShadowDepth="2" Opacity="0.1" BlurRadius="8"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="🎨 Map Style: " 
                              FontSize="13" 
                              Foreground="#666666"
                              VerticalAlignment="Center"
                              Margin="0,0,5,0"/>
                    <TextBlock Text="{Binding MapStyle}" 
                              FontSize="13" 
                              FontWeight="SemiBold"
                              Foreground="#4a7c2c"
                              VerticalAlignment="Center"/>
                    <TextBlock Text=" | 🔍 Zoom: " 
                              FontSize="13" 
                              Foreground="#666666"
                              VerticalAlignment="Center"
                              Margin="20,0,5,0"/>
                    <TextBlock Text="{Binding ZoomLevel}" 
                              FontSize="13" 
                              FontWeight="SemiBold"
                              Foreground="#4a7c2c"
                              VerticalAlignment="Center"/>
                </StackPanel>

                <Button Grid.Column="1"
                       Content="📥 Xuất bản đồ"
                       Background="Transparent"
                       Foreground="#2196F3"
                       BorderBrush="#2196F3"
                       BorderThickness="1"
                       Padding="15,8"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Cursor="Hand"
                       Command="{Binding ExportMapCommand}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                               BorderBrush="{TemplateBinding BorderBrush}"
                                               BorderThickness="{TemplateBinding BorderThickness}"
                                               CornerRadius="6"
                                               Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E3F2FD"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>

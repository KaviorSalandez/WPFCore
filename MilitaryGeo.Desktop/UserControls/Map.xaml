<UserControl x:Class="MilitaryGeo.Desktop.UserControls.Map"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MilitaryGeo.Desktop.UserControls"
             xmlns:esri="http://schemas.esri.com/arcgis/runtime/2013"
             xmlns:converters="clr-namespace:MilitaryGeo.Desktop.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200"
             Background="#F5F5F5">

    <UserControl.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <Border Grid.Row="0" 
                Background="White"
                CornerRadius="12"
                Padding="25"
                Margin="0,0,0,20">
            <Border.Effect>
                <DropShadowEffect Color="Black" Direction="270" ShadowDepth="2" Opacity="0.1" BlurRadius="8"/>
            </Border.Effect>
            
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="🗺️ Quản lý bản đồ GIS" 
                              FontSize="24" 
                              FontWeight="Bold"
                              Foreground="#333333"
                              Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding CurrentCoordinates}"
                              FontSize="13" 
                              Foreground="#666666"/>
                </StackPanel>

                <StackPanel Grid.Column="1" 
                           Orientation="Horizontal"
                           VerticalAlignment="Center">
                    <TextBlock Text="Total Markers: "
                              FontSize="13"
                              Foreground="#666666"
                              VerticalAlignment="Center"
                              Margin="0,0,5,0"/>
                    <TextBlock Text="{Binding TotalMarkers}"
                              FontSize="20"
                              FontWeight="Bold"
                              Foreground="#4a7c2c"
                              VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel - Controls -->
            <Border Grid.Column="0" 
                    Background="White"
                    CornerRadius="12"
                    Padding="20">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Direction="270" ShadowDepth="2" Opacity="0.1" BlurRadius="8"/>
                </Border.Effect>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- Search Section -->
                        <TextBlock Text="🔍 Tìm kiếm vị trí" 
                                  FontSize="16" 
                                  FontWeight="Bold"
                                  Foreground="#333333"
                                  Margin="0,0,0,15"/>

                        <Grid Margin="0,0,0,20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBox Grid.Row="0"
                                    Text="{Binding SearchLocation, UpdateSourceTrigger=PropertyChanged}"
                                    FontSize="13"
                                    Padding="12"
                                    Margin="0,0,0,10"
                                    BorderBrush="#CCCCCC"
                                    BorderThickness="1"/>

                            <Button Grid.Row="1"
                                   Content="🔎 Tìm kiếm"
                                   Background="#4a7c2c"
                                   Foreground="White"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Padding="0,10"
                                   BorderThickness="0"
                                   Cursor="Hand"
                                   Command="{Binding SearchLocationCommand}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                           CornerRadius="6"
                                                           Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#3d6624"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>

                        <!-- Map Style -->
                        <TextBlock Text="🎨 Kiểu bản đồ" 
                                  FontSize="16" 
                                  FontWeight="Bold"
                                  Foreground="#333333"
                                  Margin="0,0,0,15"/>

                        <ComboBox ItemsSource="{Binding MapStyles}"
                                 SelectedItem="{Binding MapStyle}"
                                 FontSize="13"
                                 Padding="12"
                                 Margin="0,0,0,20"/>

                        <!-- Zoom Controls -->
                        <TextBlock Text="🔍 Mức phóng to" 
                                  FontSize="16" 
                                  FontWeight="Bold"
                                  Foreground="#333333"
                                  Margin="0,0,0,15"/>

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0"
                                   Content="➖"
                                   Width="40"
                                   Height="40"
                                   FontSize="18"
                                   Margin="0,0,5,0"
                                   Command="{Binding ZoomOutCommand}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#F5F5F5"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#E0E0E0"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <TextBlock Grid.Column="1"
                                      Text="{Binding ZoomLevel}"
                                      FontSize="20"
                                      FontWeight="Bold"
                                      Foreground="#4a7c2c"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>

                            <Button Grid.Column="2"
                                   Content="➕"
                                   Width="40"
                                   Height="40"
                                   FontSize="18"
                                   Margin="5,0,0,0"
                                   Command="{Binding ZoomInCommand}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#F5F5F5"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#E0E0E0"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>

                        <!-- Quick Actions -->
                        <TextBlock Text="⚡ Thao tác nhanh" 
                                  FontSize="16" 
                                  FontWeight="Bold"
                                  Foreground="#333333"
                                  Margin="0,0,0,15"/>

                        <Button Content="📍 Thêm Marker"
                               Margin="0,0,0,10"
                               Command="{Binding AddMarkerCommand}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#E3F2FD"/>
                                    <Setter Property="Foreground" Value="#2196F3"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="0,12"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#BBDEFB"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="📏 Đo khoảng cách"
                               Margin="0,0,0,10"
                               Command="{Binding ToggleMeasureDistanceCommand}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#FFF3E0"/>
                                    <Setter Property="Foreground" Value="#FF9800"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="0,12"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMeasuringDistance}" Value="True">
                                            <Setter Property="Background" Value="#FF9800"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="Content" Value="📏 Đang đo... (Nhấp để dừng)"/>
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#FFE0B2"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="📐 Đo diện tích"
                               Margin="0,0,0,10"
                               Command="{Binding ToggleMeasureAreaCommand}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#F3E5F5"/>
                                    <Setter Property="Foreground" Value="#9C27B0"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="0,12"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMeasuringArea}" Value="True">
                                            <Setter Property="Background" Value="#9C27B0"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="Content" Value="📐 Đang đo... (Nhấp để dừng)"/>
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#E1BEE7"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="🌍 Về Hà Nội"
                               Margin="0,0,0,10"
                               Command="{Binding GetMyLocationCommand}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#E8F5E9"/>
                                    <Setter Property="Foreground" Value="#4CAF50"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="0,12"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#C8E6C9"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="🔄 Reset View"
                               Margin="0,0,0,20"
                               Command="{Binding ResetViewCommand}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#FFEBEE"/>
                                    <Setter Property="Foreground" Value="#F44336"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="0,12"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#FFCDD2"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Markers List -->
                        <TextBlock Text="📍 Danh sách Markers" 
                                  FontSize="16" 
                                  FontWeight="Bold"
                                  Foreground="#333333"
                                  Margin="0,0,0,15"/>

                        <ListBox ItemsSource="{Binding Markers}"
                                Height="250"
                                BorderBrush="#CCCCCC"
                                BorderThickness="1">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F5F5F5"
                                           CornerRadius="6"
                                           Padding="10"
                                           Margin="0,2">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0"
                                                      Text="{Binding Name}"
                                                      FontWeight="Bold"
                                                      FontSize="13"
                                                      Foreground="#333333"/>
                                            
                                            <TextBlock Grid.Row="1"
                                                      FontSize="11"
                                                      Foreground="#666666"
                                                      Margin="0,3,0,0">
                                                <Run Text="Type: "/><Run Text="{Binding Type}" FontWeight="SemiBold"/>
                                            </TextBlock>

                                            <TextBlock Grid.Row="2"
                                                      FontSize="10"
                                                      Foreground="#888888"
                                                      Margin="0,2,0,0">
                                                <Run Text="Lat: "/><Run Text="{Binding Latitude, StringFormat=F4}"/>
                                                <Run Text=" | Lon: "/><Run Text="{Binding Longitude, StringFormat=F4}"/>
                                            </TextBlock>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Button Content="🗑️ Xóa tất cả Markers"
                               Margin="0,10,0,0"
                               Command="{Binding ClearAllMarkersCommand}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#F44336"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="0,8"/>
                                    <Setter Property="BorderBrush" Value="#F44336"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" 
                                                       BorderBrush="{TemplateBinding BorderBrush}"
                                                       BorderThickness="{TemplateBinding BorderThickness}"
                                                       CornerRadius="6" 
                                                       Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#FFEBEE"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Right Panel - ArcGIS MapView -->
            <Border Grid.Column="2" 
                    Background="White"
                    CornerRadius="12"
                    Padding="5">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Direction="270" ShadowDepth="2" Opacity="0.1" BlurRadius="8"/>
                </Border.Effect>

                <Grid>
                    <!-- ArcGIS MapView -->
                    <esri:MapView x:Name="MainMapView" ClipToBounds="True"/>

                    <!-- Active Tool Indicator (hien thi khi dang do luong) -->
                    <Border HorizontalAlignment="Center" VerticalAlignment="Top"
                            Margin="0,12,0,0" Padding="12,7" CornerRadius="20"
                            Background="#CC1565C0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMeasuringDistance}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsMeasuringArea}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="White">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value=""/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMeasuringDistance}" Value="True">
                                                <Setter Property="Text" Value="📏 Chế độ đo khoảng cách — Nhấp lên bản đồ để thêm điểm"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsMeasuringArea}" Value="True">
                                                <Setter Property="Text" Value="📐 Chế độ đo diện tích — Nhấp lên bản đồ để thêm điểm"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <Button Content="✕" Background="Transparent" BorderThickness="0"
                                    Foreground="White" FontSize="13" Cursor="Hand"
                                    Margin="10,0,0,0" Padding="0"
                                    Command="{Binding ToggleMeasureDistanceCommand}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <ContentPresenter/>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMeasuringDistance}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="✕" Background="Transparent" BorderThickness="0"
                                    Foreground="White" FontSize="13" Cursor="Hand"
                                    Margin="10,0,0,0" Padding="0"
                                    Command="{Binding ToggleMeasureAreaCommand}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <ContentPresenter/>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMeasuringArea}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Measurement Result Panel -->
                    <Border HorizontalAlignment="Left" VerticalAlignment="Bottom"
                            Margin="12,0,0,12" Padding="14,10" CornerRadius="8"
                            Background="#E6FFFFFF"
                            Visibility="{Binding MeasurementResult, 
                                Converter={StaticResource StringToVisibilityConverter}}">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" Opacity="0.15" BlurRadius="8" ShadowDepth="1"/>
                        </Border.Effect>
                        <TextBlock Text="{Binding MeasurementResult}"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="#212529"/>
                    </Border>

                    <!-- Loading Overlay -->
                    <Border Background="#80000000"
                           Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="⏳" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="Đang xử lý..." FontSize="16" Foreground="White"
                                      FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- Footer Section -->
        <Border Grid.Row="2" 
                Background="White"
                CornerRadius="12"
                Padding="20,15"
                Margin="0,20,0,0">
            <Border.Effect>
                <DropShadowEffect Color="Black" Direction="270" ShadowDepth="2" Opacity="0.1" BlurRadius="8"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="🎨 Map Style: " 
                              FontSize="13" 
                              Foreground="#666666"
                              VerticalAlignment="Center"
                              Margin="0,0,5,0"/>
                    <TextBlock Text="{Binding MapStyle}" 
                              FontSize="13" 
                              FontWeight="SemiBold"
                              Foreground="#4a7c2c"
                              VerticalAlignment="Center"/>
                    <TextBlock Text=" | 🔍 Zoom: " 
                              FontSize="13" 
                              Foreground="#666666"
                              VerticalAlignment="Center"
                              Margin="20,0,5,0"/>
                    <TextBlock Text="{Binding ZoomLevel}" 
                              FontSize="13" 
                              FontWeight="SemiBold"
                              Foreground="#4a7c2c"
                              VerticalAlignment="Center"/>
                </StackPanel>

                <Button Grid.Column="1"
                       Content="📥 Xuất bản đồ"
                       Background="Transparent"
                       Foreground="#2196F3"
                       BorderBrush="#2196F3"
                       BorderThickness="1"
                       Padding="15,8"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Cursor="Hand"
                       Command="{Binding ExportMapCommand}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                               BorderBrush="{TemplateBinding BorderBrush}"
                                               BorderThickness="{TemplateBinding BorderThickness}"
                                               CornerRadius="6"
                                               Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E3F2FD"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>

<Window x:Class="MilitaryGeo.Desktop.MainWorkSpace"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:local="clr-namespace:MilitaryGeo.Desktop"
        xmlns:converters="clr-namespace:MilitaryGeo.Desktop.Converters"
        xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
        xmlns:skin="clr-namespace:Syncfusion.SfSkinManager;assembly=Syncfusion.SfSkinManager.WPF"
        skin:SfSkinManager.Theme="{skin:SkinManagerExtension ThemeName=MaterialLight}"
        mc:Ignorable="d"
        Title="Military Geo - Hệ thống quản lý dữ liệu địa lý quân sự" 
        Height="800" 
        Width="1400"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#F5F5F5">

    <Window.Resources>
        <!-- Converters -->
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:SettingsSeparatorConverter x:Key="SettingsSeparatorConverter"/>

        <!-- Sidebar Button Style - IMPROVED VERSION -->
        <Style x:Key="SidebarButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E8F5E9"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,0,15,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Margin" Value="8,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="MainBorder"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0,0,3,0"
                                BorderBrush="Transparent"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="10"
                                Margin="0">
                            <ContentPresenter VerticalAlignment="Center"
                                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="MainBorder" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#FFFFFF" Offset="0"/>
                                            <GradientStop Color="#F5F5F5" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="#4a7c2c"/>
                                <Setter Property="Foreground" Value="#2d5a1a"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainBorder" Property="Background" Value="#5a8c3c"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="MainBorder" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#FAFAFA" Offset="0"/>
                                            <GradientStop Color="#F0F0F0" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Foreground" Value="#2d5a1a"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Icon Button Style -->
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#4a7c2c"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="20">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E8F5E9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Toggle Menu Button Style -->
        <Style x:Key="ToggleMenuButtonStyle" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <SolidColorBrush Color="White" Opacity="0.15"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Width" Value="45"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background">
                        <Setter.Value>
                            <SolidColorBrush Color="White" Opacity="0.25"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Top Navigation Bar -->
        <Border Grid.Row="0" 
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Background="White"
                BorderBrush="#E0E0E0"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo Section -->
                <StackPanel Grid.Column="0" 
                           Orientation="Horizontal" 
                           VerticalAlignment="Center"
                           Margin="20,0">
                    <Ellipse Width="35" Height="35" Fill="#4a7c2c" Margin="0,0,10,0">
                        <Ellipse.OpacityMask>
                            <VisualBrush>
                                <VisualBrush.Visual>
                                    <Grid>
                                        <Path Fill="White" 
                                              Data="M12,2 L17,7 L17,12 L12,17 L7,12 L7,7 Z"
                                              Stretch="Uniform"
                                              Margin="5"/>
                                        <Ellipse Width="8" Height="8" Fill="#FFD700"/>
                                    </Grid>
                                </VisualBrush.Visual>
                            </VisualBrush>
                        </Ellipse.OpacityMask>
                    </Ellipse>
                    <TextBlock x:Name="txtLogoText"
                              Text="MILITARY GEO" 
                              FontSize="18" 
                              FontWeight="Bold" 
                              Foreground="#4a7c2c"
                              VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Search Bar -->
                <Border Grid.Column="1" 
                       Background="#F5F5F5"
                       CornerRadius="20"
                       Margin="20,0"
                       VerticalAlignment="Center"
                       Height="40"
                       MaxWidth="600">
                    <Grid>
                        <TextBox x:Name="txtSearch"
                                Text="Tìm kiếm..."
                                FontSize="13"
                                Foreground="#999999"
                                Background="Transparent"
                                BorderThickness="0"
                                VerticalAlignment="Center"
                                Padding="20,0,40,0"
                                GotFocus="txtSearch_GotFocus"
                                LostFocus="txtSearch_LostFocus"/>
                        <TextBlock Text="🔍" 
                                  FontSize="16"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Center"
                                  Margin="0,0,15,0"
                                  IsHitTestVisible="False"/>
                    </Grid>
                </Border>

                <!-- User Profile Section -->
                <StackPanel Grid.Column="2" 
                           Orientation="Horizontal" 
                           Margin="0,0,20,0"
                           VerticalAlignment="Center">
                    
                    <!-- Notification Button -->
                    <Button Style="{StaticResource IconButtonStyle}"
                           Margin="5,0"
                           ToolTip="Thông báo">
                        <TextBlock Text="🔔" FontSize="18"/>
                    </Button>

                    <!-- Settings Button -->
                    <Button Style="{StaticResource IconButtonStyle}"
                           Margin="5,0"
                           ToolTip="Cài đặt">
                        <TextBlock Text="⚙" FontSize="18"/>
                    </Button>

                    <!-- User Profile -->
                    <Border Background="#E8F5E9"
                           CornerRadius="20"
                           Padding="10,5,15,5"
                           Margin="10,0,0,0"
                           Cursor="Hand">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="35" Height="35" 
                                    Fill="#4a7c2c"
                                    Margin="0,0,10,0">
                                <Ellipse.OpacityMask>
                                    <VisualBrush>
                                        <VisualBrush.Visual>
                                            <TextBlock Text="👤" 
                                                      FontSize="20"
                                                      Foreground="White"/>
                                        </VisualBrush.Visual>
                                    </VisualBrush>
                                </Ellipse.OpacityMask>
                            </Ellipse>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="txtUserName"
                                          Text="Administrator" 
                                          FontSize="13" 
                                          FontWeight="SemiBold"
                                          Foreground="#333333"/>
                                <TextBlock Text="Quản trị viên" 
                                          FontSize="11" 
                                          Foreground="#666666"/>
                            </StackPanel>
                            <TextBlock Text="▼" 
                                      FontSize="10" 
                                      Foreground="#666666"
                                      VerticalAlignment="Center"
                                      Margin="10,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Logout Button -->
                    <Button Style="{StaticResource IconButtonStyle}"
                           Margin="10,0,0,0"
                           ToolTip="Đăng xuất"
                           Click="btnLogout_Click">
                        <TextBlock Text="🚪" FontSize="18"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Sidebar Menu -->
        <Border x:Name="SidebarBorder"
                Grid.Row="1" 
                Grid.Column="0"
                BorderBrush="#E0E0E0"
                BorderThickness="0,0,1,0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#3d6624" Offset="0"/>
                    <GradientStop Color="#4a7c2c" Offset="0.5"/>
                    <GradientStop Color="#5a8c3c" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Toggle Menu Button -->
                <Button x:Name="btnToggleMenu"
                        Grid.Row="0"
                        Style="{StaticResource ToggleMenuButtonStyle}"
                        Margin="10,10,10,5"
                        HorizontalAlignment="Right"
                        Click="btnToggleMenu_Click"
                        ToolTip="Thu gọn/Mở rộng menu">
                    <TextBlock x:Name="txtToggleIcon" 
                              Text="☰" 
                              FontSize="22"
                              FontWeight="Bold"/>
                </Button>

                <!-- Menu Items -->
                <ScrollViewer Grid.Row="1" 
                             VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="5,5,5,10">
                        <!-- Menu Header -->
                        <TextBlock x:Name="txtMenuHeader"
                                  Text="MENU CHÍNH" 
                                  FontSize="12" 
                                  FontWeight="Bold"
                                  Foreground="#C8E6C9"
                                  Margin="18,10,15,12"/>

                        <!-- Dynamic Menu Items -->
                        <ItemsControl x:Name="MenuItemsControl" ItemsSource="{Binding MenuItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <!-- Main Menu Item -->
                                        <RadioButton Style="{StaticResource SidebarButtonStyle}"
                                                    GroupName="Menu"
                                                    Tag="{Binding ViewName}"
                                                    ToolTip="{Binding Title}"
                                                    Checked="OnDynamicMenuItemChecked"
                                                    Click="OnMenuItemClick">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Icon}" FontSize="20" Margin="0,0,15,0"/>
                                                <TextBlock Text="{Binding Title}" 
                                                          VerticalAlignment="Center"
                                                          FontWeight="SemiBold"/>
                                                <!-- Arrow for submenu -->
                                                <TextBlock Text="▼" 
                                                          FontSize="11"
                                                          Margin="8,0,0,0"
                                                          VerticalAlignment="Center"
                                                          Visibility="{Binding HasSubMenu, Converter={StaticResource BoolToVisibilityConverter}}"
                                                          RenderTransformOrigin="0.5,0.5">
                                                    <TextBlock.RenderTransform>
                                                        <RotateTransform x:Name="SubMenuArrowRotate" Angle="0"/>
                                                    </TextBlock.RenderTransform>
                                                </TextBlock>
                                            </StackPanel>
                                        </RadioButton>

                                        <!-- SubMenu Items -->
                                        <ItemsControl ItemsSource="{Binding SubMenuItems}"
                                                     Margin="25,0,0,0"
                                                     x:Name="SubMenuItemsControl"
                                                     Visibility="Collapsed">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <RadioButton Style="{StaticResource SidebarButtonStyle}"
                                                                GroupName="Menu"
                                                                Height="48"
                                                                Tag="{Binding ViewName}"
                                                                ToolTip="{Binding Title}"
                                                                Checked="OnDynamicMenuItemChecked">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding Icon}" FontSize="14" Margin="0,0,12,0" Opacity="0.8"/>
                                                            <TextBlock Text="{Binding Title}" 
                                                                      VerticalAlignment="Center"
                                                                      FontSize="14"/>
                                                        </StackPanel>
                                                    </RadioButton>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- Separator after Settings menu -->
                                        <Border Height="1" 
                                               Margin="15,18,15,18"
                                               Visibility="{Binding ViewName, Converter={StaticResource SettingsSeparatorConverter}}">
                                            <Border.Background>
                                                <SolidColorBrush Color="White" Opacity="0.2"/>
                                            </Border.Background>
                                        </Border>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Content Area -->
        <Grid Grid.Row="1" Grid.Column="1">
            <!-- Content Container -->
            <ContentControl x:Name="MainContentArea" 
                           Content="{Binding}"/>
        </Grid>
    </Grid>
</Window>
